# -------------------------------------------------------------------
# AI Engine — Nginx reverse proxy configuration
#
# Template file. ${DOMAIN} is substituted by init-letsencrypt.sh
# via envsubst before Nginx reads this config.
# -------------------------------------------------------------------

events {
    worker_connections 1024;
}

http {
    access_log /var/log/nginx/access.log;
    error_log  /var/log/nginx/error.log warn;

    # Match Fastify 25 MB upload limit
    client_max_body_size 25m;

    # LLM / proposal generation can take several minutes
    proxy_connect_timeout 600s;
    proxy_send_timeout    600s;
    proxy_read_timeout    600s;
    send_timeout          600s;

    # ── HTTP: redirect to HTTPS (except ACME challenge) ──────────
    server {
        listen 80;
        server_name _;

        location /.well-known/acme-challenge/ {
            root /var/www/certbot;
        }

        location / {
            return 301 https://$host$request_uri;
        }
    }

    # ── HTTPS: proxy to UI (apex + all subdomains) ──────────────
    server {
        listen 443 ssl;
        server_name ${DOMAIN} *.${DOMAIN};

        ssl_certificate     /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;

        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_prefer_server_ciphers on;
        ssl_session_cache shared:SSL:10m;
        ssl_session_timeout 1d;

        location / {
            proxy_pass         http://ui:3001;
            proxy_http_version 1.1;

            # Required for SSE streaming responses
            proxy_set_header   Connection "";
            proxy_buffering    off;
            proxy_cache        off;

            # Standard proxy headers
            proxy_set_header   Host              $host;
            proxy_set_header   X-Real-IP         $remote_addr;
            proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto $scheme;
        }
    }
}
