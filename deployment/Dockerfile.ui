# -------------------------------------------------------------------
# AI Engine — UI image
#
# Next.js standalone app for proposal generation and knowledge queries.
# Pure Node.js — no Python needed.
#
#   docker build -f deployment/Dockerfile.ui -t ai-engine-ui .
# -------------------------------------------------------------------

# ── Stage 1: build ────────────────────────────────────────────────
FROM node:22-bookworm-slim AS build

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY packages/ packages/
COPY agents/ agents/
COPY plugins/ plugins/
COPY services/ services/

RUN pnpm install --frozen-lockfile

# Ensure public dir exists — Next.js doesn't create it if absent, but the
# runtime stage copies it unconditionally so it must be present after build.
RUN mkdir -p /app/services/ui/public

# API_URL must be set at build time — Next.js bakes rewrites into the build output.
# NEXT_STANDALONE=1 enables output: 'standalone' so the runtime stage can copy
# the self-contained server bundle (required by the COPY steps below).
# NEXT_PUBLIC_* vars are also baked at build time — pass via --build-arg.
ARG NEXT_PUBLIC_MICROSITE_ROOT_DOMAIN=
ARG NEXT_PUBLIC_MICROSITE_CNAME_TARGET=
ARG NEXT_PUBLIC_MICROSITE_SERVER_IP=
ENV API_URL=http://api:3000
ENV NEXT_STANDALONE=1
ENV NEXT_PUBLIC_MICROSITE_ROOT_DOMAIN=$NEXT_PUBLIC_MICROSITE_ROOT_DOMAIN
ENV NEXT_PUBLIC_MICROSITE_CNAME_TARGET=$NEXT_PUBLIC_MICROSITE_CNAME_TARGET
ENV NEXT_PUBLIC_MICROSITE_SERVER_IP=$NEXT_PUBLIC_MICROSITE_SERVER_IP
RUN pnpm build

# ── Stage 2: runtime ─────────────────────────────────────────────
FROM node:20-slim

WORKDIR /app

# Next.js standalone output includes everything needed
COPY --from=build /app/services/ui/.next/standalone ./
COPY --from=build /app/services/ui/.next/static ./services/ui/.next/static
COPY --from=build /app/services/ui/public ./services/ui/public

ENV NODE_ENV=production
ENV PORT=3001
ENV HOSTNAME=0.0.0.0
ENV API_URL=http://api:3000

EXPOSE 3001

CMD ["node", "services/ui/server.js"]
