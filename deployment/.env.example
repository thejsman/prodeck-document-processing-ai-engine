# -------------------------------------------------------------------
# AI Engine — Environment Configuration
#
# Copy this file to .env and edit as needed:
#   cp .env.example .env
# -------------------------------------------------------------------

# LLM provider: "ollama" (default, local) or "openai" (cloud)
LLM_PROVIDER=ollama

# ── Ollama (local) ────────────────────────────────────────────────
# These apply when LLM_PROVIDER=ollama.
# OLLAMA_BASE_URL is set automatically inside Docker Compose.
OLLAMA_GENERATION_MODEL=mistral
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_PORT=11434

# ── OpenAI (optional) ────────────────────────────────────────────
# Only required when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── API service ──────────────────────────────────────────────────
# Relative to services/api/ (where pnpm runs the script from)
WORKDIR=../../workdir
API_PORT=3000

# ── Web UI ──────────────────────────────────────────────────────
UI_PORT=3001

# ── AWS S3 Storage (optional) ────────────────────────────────────
# Only required when a namespace config sets "storage.type": "s3".
# Bucket name and region are set per-namespace in:
#   workdir/config/namespaces/<namespace>.json
# These env vars provide the AWS credentials used by all S3 namespaces.
#
# Option A — access key pair (dev / CI):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
#
# Option B — IAM role (EC2 / ECS / Lambda production):
#   No credentials needed here — the SDK picks up the attached role automatically.
#
# Leave all AWS_ vars empty to keep using local filesystem storage (default).

# ── Qdrant Vector Store (optional) ────────────────────────────────
# Required only for namespaces that have "vectorStore.type": "qdrant".
# You can set the URL here as a global default, or set "vectorStore.url"
# per namespace in workdir/config/namespaces/<namespace>.json.
QDRANT_URL=http://qdrant:6333
