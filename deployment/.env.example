# -------------------------------------------------------------------
# AI Engine — Environment Configuration
#
# Copy this file to .env and edit as needed:
#   cp .env.example .env
# -------------------------------------------------------------------

# LLM provider: "ollama" (default, local), "openai", "anthropic", or "nvidia"
LLM_PROVIDER=ollama

# ── Ollama (local) ────────────────────────────────────────────────
# These apply when LLM_PROVIDER=ollama.
# OLLAMA_BASE_URL is set automatically inside Docker Compose.
OLLAMA_GENERATION_MODEL=mistral
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_PORT=11434

# ── OpenAI (optional) ────────────────────────────────────────────
# Only required when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ── Anthropic (optional) ─────────────────────────────────────────
# Only required when LLM_PROVIDER=anthropic.
# Note: Anthropic has no native embeddings API — set EMBEDDING_PROVIDER below.
ANTHROPIC_API_KEY=
ANTHROPIC_GENERATION_MODEL=claude-sonnet-4-6

# ── Voyage AI (optional) ─────────────────────────────────────────
# Embeddings-only provider. Recommended when LLM_PROVIDER=anthropic.
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-4

# ── Embedding provider ───────────────────────────────────────────
# Controls which provider handles embeddings for ingest and query.
# Options: voyage, openai, ollama
# When LLM_PROVIDER=anthropic and this is unset, auto-detects from
# available API keys: voyage → openai → ollama.
EMBEDDING_PROVIDER=

# ── NVIDIA NIM (optional) ────────────────────────────────────────
# Only required when LLM_PROVIDER=nvidia.
# Free API keys: https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_GENERATION_MODEL=moonshotai/kimi-k2.6
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
NVIDIA_TEMPERATURE=0

# ── API service ──────────────────────────────────────────────────
# Relative to services/api/ (where pnpm runs the script from)
WORKDIR=../../workdir
API_PORT=3000

# ── Web UI ──────────────────────────────────────────────────────
UI_PORT=3001

# ── AWS S3 Storage (optional) ────────────────────────────────────
# Only required when a namespace config sets "storage.type": "s3".
# Bucket name and region are set per-namespace in:
#   workdir/config/namespaces/<namespace>.json
# These env vars provide the AWS credentials used by all S3 namespaces.
#
# Option A — access key pair (dev / CI):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
#
# Option B — IAM role (EC2 / ECS / Lambda production):
#   No credentials needed here — the SDK picks up the attached role automatically.
#
# Leave all AWS_ vars empty to keep using local filesystem storage (default).

# ── Vector Store ──────────────────────────────────────────────────
# Controls which vector store backend is used for indexing and search.
# "faiss" (default) — local FAISS index files via Python subprocess.
# "qdrant"          — native Node.js Qdrant client (no Python cold start).
VECTOR_STORE=faiss

# Qdrant — used when VECTOR_STORE=qdrant or a namespace config sets
# "vectorStore.type": "qdrant". You can also override per namespace in:
#   workdir/config/namespaces/<namespace>.json
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# For Qdrant Cloud: set your cluster API key here (leave empty for local Docker).
QDRANT_API_KEY=

# ── Ingestion performance (Phase 2 & 3) ──────────────────────────
# Set to "false" to fall back to the legacy sequential pipeline.
INGEST_PARALLEL=true
INGEST_UNIFIED_LLM=true
MAX_EXCERPT_CHARS=32000
