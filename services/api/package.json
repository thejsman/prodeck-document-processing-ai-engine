{
  "name": "@ai-engine/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lightweight HTTP adapter over the AI Engine runtime",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/skills',{recursive:true});fs.copyFileSync('src/skills/frontend-design.md','dist/skills/frontend-design.md')\"",
    "start": "node --env-file=../../deployment/.env dist/index.js",
    "dev": "tsc --watch --preserveWatchOutput & node --env-file=../../deployment/.env --watch-path=./dist dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "site-facts:extract": "node --env-file=../../deployment/.env dist/site-facts/cli.js"
  },
  "dependencies": {
    "@ai-engine/agent-design-editor": "workspace:*",
    "@ai-engine/agent-microsite-generator": "workspace:*",
    "@ai-engine/agent-proposal-section": "workspace:*",
    "@ai-engine/core": "workspace:*",
    "@ai-engine/planner": "workspace:*",
    "@ai-engine/plugin-proposal-generator": "workspace:*",
    "@ai-engine/runtime": "workspace:*",
    "@ai-engine/tool-analyze-image": "workspace:*",
    "@ai-engine/tool-extract-section": "workspace:*",
    "@ai-engine/tool-generate-content": "workspace:*",
    "@ai-engine/tool-generate-mermaid": "workspace:*",
    "@ai-engine/tool-save-asset": "workspace:*",
    "@ai-engine/tool-search-documents": "workspace:*",
    "@fastify/multipart": "^9.4.0",
    "docx": "^9.7.1",
    "fastify": "^5.2.1",
    "js-yaml": "^4.1.0",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.40.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/pdf-parse": "^1.1.4",
    "vitest": "^4.0.18"
  }
}
