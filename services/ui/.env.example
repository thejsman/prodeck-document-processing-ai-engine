# API service URL (used by Next.js rewrites)
API_URL=http://localhost:3000

# ── Microsite publishing (see deployment/MICROSITE_AWS_SETUP.md) ──
AWS_REGION=us-east-1
MICROSITE_S3_BUCKET=microsites-static-assets
# Server-side: used to build the live URL returned by /api/publish and to
# detect subdomain hosts in middleware.ts.
MICROSITE_ROOT_DOMAIN=yourdomain.com
# Client-side: shown in the publish dialog's domain preview. Must match
# MICROSITE_ROOT_DOMAIN.
NEXT_PUBLIC_MICROSITE_ROOT_DOMAIN=yourdomain.com
# Provide explicit creds or rely on an IAM role attached to the task/instance.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Custom domain publishing ─────────────────────────────────────────────────
# Set to 'true' to enable custom domain routing in middleware and the
# Custom Domain section in the Publish modal.
MICROSITE_CUSTOM_DOMAINS_ENABLED=false

# The CNAME target users should point their subdomain to.
# Create an A record for this hostname pointing to your server IP.
# Example: sites.yourdomain.com
MICROSITE_CNAME_TARGET=

# Your server's public IP address — shown for root domain (A record) setup.
MICROSITE_SERVER_IP=

# Client-side copies of the above — shown in the publish modal DNS instructions.
NEXT_PUBLIC_MICROSITE_CNAME_TARGET=
NEXT_PUBLIC_MICROSITE_SERVER_IP=

# Internal URL of the cert-manager sidecar (Docker network only).
# Leave blank if cert-manager is not running (e.g. local dev without Docker).
CERT_MANAGER_URL=http://cert-manager:3002

# Email used for Let's Encrypt certificate registration via cert-manager.
CERTBOT_EMAIL=
